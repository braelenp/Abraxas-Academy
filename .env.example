# Email Configuration
RESEND_API_KEY=your_resend_api_key_here

# Solana Network Configuration
# Options: devnet, testnet, mainnet-beta
VITE_SOLANA_NETWORK=mainnet-beta
VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com

# Metaplex & NFT Configuration (Frontend - safe to expose)
VITE_CANDY_MACHINE_ID=your_candy_machine_address
VITE_COLLECTION_MINT=your_collection_mint_address

# Backend Solana Configuration (Server-side only - KEEP SECRET)
# SOLANA_KEYPAIR should be your wallet's secret key as a JSON array
# WARNING: Never commit this to version control!
SOLANA_KEYPAIR=[1,2,3,...]  # DO NOT COMMIT
SOLANA_NETWORK=mainnet-beta
CANDY_MACHINE_ID=your_candy_machine_address
COLLECTION_MINT=your_collection_mint_address

# Bundlr Configuration (for future asset uploads)
BUNDLR_NODE=https://node1.bundlr.network

# Mint Configuration
MINT_PRICE=2  # Price in SOL (e.g., 2 SOL per Genesis NFT)
CREATOR_WALLET=your_creator_wallet_address  # Receives SOL from mints

# Solana Endpoint Backups
BACKUP_RPC_1=https://solana-mainnet.rpc.extrnode.com:8899
BACKUP_RPC_2=https://rpc.ankr.com/solana
