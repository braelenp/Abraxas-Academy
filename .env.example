# ────────────────────────────────────────────────────────────────
# ABRAXAS ACADEMY - ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and fill in your values
# ────────────────────────────────────────────────────────────────

# ─── EMAIL SERVICE ─────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here

# ─── BLOCKCHAIN NETWORK ────────────────────────────────────────
# Solana Network: "devnet" for testing, "mainnet-beta" for production
VITE_SOLANA_NETWORK=devnet
VITE_SOLANA_RPC=https://api.devnet.solana.com

# ─── GENESIS NFT COLLECTION (CRITICAL) ─────────────────────────
# These are required for NFT minting to work
# 1. Run: npx ts-node scripts/createGenesisCollection.ts
# 2. Copy the output addresses here:
VITE_COLLECTION_MINT=your_collection_mint_address_here
VITE_CREATOR_WALLET=your_creator_wallet_address_here

# ─── BACKEND CONFIGURATION ─────────────────────────────────────
# Server-side RPC (for read operations only)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# ─── FUTURE: CANDY MACHINE (Not currently used) ────────────────
# These are for future candy machine integration
VITE_CANDY_MACHINE_ID=your_candy_machine_id_here
CANDY_MACHINE_ID=your_candy_machine_id_here

# ─── MINT CONFIGURATION (Not currently used) ──────────────────
# These are placeholders for future mint pricing
MINT_PRICE=2
CREATOR_WALLET=your_wallet_here
