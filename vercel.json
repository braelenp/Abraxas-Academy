{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "RESEND_API_KEY": "@resend_api_key"
  },
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
