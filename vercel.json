{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1",
      "status": 200
    },
    {
      "src": "^/index\\.html$",
      "dest": "/index.html"
    },
    {
      "src": "^/(.*)\\.js$",
      "dest": "/$1.js",
      "status": 200
    },
    {
      "src": "^/(.*)\\.css$",
      "dest": "/$1.css",
      "status": 200
    },
    {
      "src": ".*",
      "dest": "/index.html"
    }
  ]
}
